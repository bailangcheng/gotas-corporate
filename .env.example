NEXT_PUBLIC_SITE_URL=http://localhost:3000

# microCMS (server-side only). When unset, the CMS adapter falls back to mock posts.
MICROCMS_SERVICE_DOMAIN=
MICROCMS_API_KEY=

# microCMS Webhook → /api/revalidate（オンデマンド再生成）の署名キー。
# 未設定なら /api/revalidate は 503 を返す（開けっ放しにしない）。
MICROCMS_WEBHOOK_SECRET=

# microCMS Management(Write) API キー。scripts/seed-cms.mjs（記事の自動投入）専用。
# 本番ランタイムでは不要。未設定なら MICROCMS_API_KEY にフォールバック。
MICROCMS_MANAGEMENT_API_KEY=

# Resend (server-side only). Used by /api/inquiry.
RESEND_API_KEY=
INQUIRY_FROM_EMAIL=
INQUIRY_TO_EMAIL=

# Optional per-channel overrides for /api/inquiry.
# CONTACT_RESEND_API_KEY=
# CONTACT_INQUIRY_FROM_EMAIL=
# CONTACT_INQUIRY_TO_EMAIL=
# MEETING_RESEND_API_KEY=
# MEETING_INQUIRY_FROM_EMAIL=
# MEETING_INQUIRY_TO_EMAIL=
