NEXT_PUBLIC_SITE_URL=http://localhost:3000

# microCMS (server-side only). When unset, the CMS adapter falls back to mock posts.
MICROCMS_SERVICE_DOMAIN=
MICROCMS_API_KEY=

# Resend (server-side only). Used by /api/inquiry.
RESEND_API_KEY=
INQUIRY_FROM_EMAIL=
INQUIRY_TO_EMAIL=

